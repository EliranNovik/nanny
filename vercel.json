{
  "buildCommand": "cd apps/web && npm install && npm run build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/((?!assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/p/:id",
      "destination": "/posts/:id",
      "permanent": true
    },
    {
      "source": "/r/:id",
      "destination": "/requests/:id",
      "permanent": true
    },
    {
      "source": "/community/feed",
      "has": [{ "type": "query", "key": "post", "value": "(?<id>.*)" }],
      "destination": "/posts/:id",
      "permanent": true
    },
    {
      "source": "/community/feed",
      "has": [{ "type": "query", "key": "request", "value": "(?<id>.*)" }],
      "destination": "/requests/:id",
      "permanent": true
    }
  ]
}
